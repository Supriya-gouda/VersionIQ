# Environment & Runtime
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# MongoDB Configuration
# For Local MongoDB: mongodb://localhost:27017/version_vault
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/version_vault?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/version_vault

# Authentication & Security
JWT_SECRET=replace_with_a_long_secure_secret_at_least_32_characters_long_for_production
JWT_EXPIRES_IN=1d

# Client Configuration
# Comma-separated list of allowed browser origins for CORS.
# Include every origin the browser will use to open the app:
#   http://localhost:5173  → Vite default dev port
#   http://localhost:8080  → lovable vite-tanstack-config forces this port
#   http://localhost:8081  → Vite fallback if 8080 is taken
#   http://localhost:3000  → Docker frontend container (vite preview)
CLIENT_ORIGIN=http://localhost:5173,http://localhost:8080,http://localhost:8081,http://localhost:3000

# File Upload Configuration
UPLOAD_ROOT=uploads
MAX_UPLOAD_SIZE_BYTES=104857600

# Rate Limiting
ENABLE_RATE_LIMIT=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# OpenAI Integration (Optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gemini Integration (Optional)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Jenkins CI/CD Integration (Optional)
# Set JENKINS_BASE_URL to enable pull-based sync from Jenkins REST API.
# Set JENKINS_WEBHOOK_SECRET to secure the /pipelines/webhook endpoint that
# Jenkins calls at the end of every build to push results into MongoDB.
JENKINS_BASE_URL=http://localhost:8080
JENKINS_USER=admin
JENKINS_TOKEN=
JENKINS_JOB_NAME=version-vault
JENKINS_WEBHOOK_SECRET=
