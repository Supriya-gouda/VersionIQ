# Environment & Runtime
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# MongoDB Configuration
# Local: mongodb://localhost:27017/version_vault
# Atlas example: mongodb+srv://username:password@cluster.mongodb.net/version_vault?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/version_vault

# Authentication & Security
# Replace JWT_SECRET with the generated secret below (or keep this value for local dev)
JWT_SECRET=0f3b1a9c5d7e2f248b6a9e1f0c4d2b7f9a6c3e2b8d1f4a6c7b9e2d3f1a5b6c7
JWT_EXPIRES_IN=1d

# Client Configuration (allow multiple dev origins)
# Comma-separated list.
# - http://localhost:5173  → Vite default dev port
# - http://localhost:8080  → Vite actual dev port (lovable config forces 8080)
# - http://localhost:8081  → Vite fallback if 8080 is taken
# - http://localhost:3000  → Docker frontend container (vite preview)
CLIENT_ORIGIN=http://localhost:5173,http://localhost:8080,http://localhost:8081,http://localhost:3000

# File Upload Configuration
UPLOAD_ROOT=uploads
MAX_UPLOAD_SIZE_BYTES=104857600

# Rate Limiting
ENABLE_RATE_LIMIT=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# OpenAI Integration (Optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gemini Integration (Optional)
GEMINI_API_KEY=AIzaSyDBh9zk4WK8O0vQl7iUBR62L72hvdXJJ6U
GEMINI_MODEL=gemini-flash-latest

# Jenkins CI/CD Integration (Optional)
# Both backend and Jenkins run inside the same Docker network (version-vault-network).
# Use the Docker Compose service name "jenkins" — not localhost — so the backend
# can reach Jenkins via container-to-container DNS resolution.
JENKINS_BASE_URL=http://localhost:8080/
JENKINS_USER=admin
JENKINS_TOKEN=admin
JENKINS_JOB_NAME=VersionIQ-Pipeline
# Shared secret for POST /pipelines/webhook — must match X-Jenkins-Token in Jenkinsfile
JENKINS_WEBHOOK_SECRET=11030d20832c84dcafa04cba505511b0f7