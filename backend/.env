# Environment & Runtime
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# MongoDB Configuration
# Local: mongodb://localhost:27017/version_vault
# Atlas example: mongodb+srv://username:password@cluster.mongodb.net/version_vault?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/version_vault

# Authentication & Security
# Replace JWT_SECRET with the generated secret below (or keep this value for local dev)
JWT_SECRET=0f3b1a9c5d7e2f248b6a9e1f0c4d2b7f9a6c3e2b8d1f4a6c7b9e2d3f1a5b6c7
JWT_EXPIRES_IN=1d

# Client Configuration (allow multiple dev origins)
# Comma-separated list; include the default Vite port and the actual dev port Vite selected (8081)
CLIENT_ORIGIN=http://localhost:5173,http://localhost:8081

# File Upload Configuration
UPLOAD_ROOT=uploads
MAX_UPLOAD_SIZE_BYTES=104857600

# Rate Limiting
ENABLE_RATE_LIMIT=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# OpenAI Integration (Optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gemini Integration (Optional)
GEMINI_API_KEY=AIzaSyBquADM9z-u2skx-K8iSZcTvJ5GCtWrXVE
GEMINI_MODEL=gemini-1.5-flash

# Jenkins CI/CD Integration (Optional)
JENKINS_BASE_URL=http://localhost:8080
JENKINS_USER=admin
JENKINS_TOKEN=
JENKINS_JOB_NAME=version-vault