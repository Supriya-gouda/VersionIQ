# ─────────────────────────────────────────────────────────────────────────────
# VersionIQ — Root environment variables
#
# Copy to .env and fill in values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# VITE_API_BASE_URL is baked into the JS bundle at build time by Vite.
# It must be the URL the USER'S BROWSER will use to reach the backend.
#
# Local dev (npm run dev):
#   VITE_API_BASE_URL=http://localhost:4000
#
# Docker (docker compose up):
#   VITE_API_BASE_URL=http://localhost:4000
#   (browser → host → backend container on port 4000 — same value)
#
# Production (different host):
#   VITE_API_BASE_URL=https://api.yourdomain.com
VITE_API_BASE_URL=http://localhost:4000

# ── Backend ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://localhost:27017/version_vault
JWT_SECRET=replace_with_a_long_secure_secret
JWT_EXPIRES_IN=1d

# CLIENT_ORIGIN — comma-separated list of browser origins allowed by CORS.
# The lovable @vite-tanstack-config package forces the dev server to port 8080
# (or 8081 if 8080 is taken).  Port 3000 is the Docker vite preview port.
CLIENT_ORIGIN=http://localhost:5173,http://localhost:8080,http://localhost:8081,http://localhost:3000

UPLOAD_ROOT=uploads
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Jenkins CI/CD ─────────────────────────────────────────────────────────────
JENKINS_BASE_URL=http://localhost:8080
JENKINS_USER=admin
JENKINS_TOKEN=
JENKINS_JOB_NAME=version-vault
# Shared secret for POST /pipelines/webhook — leave blank to skip auth check in dev
JENKINS_WEBHOOK_SECRET=

# ── Docker Compose overrides (used by docker-compose.yml) ────────────────────
# MongoDB root credentials (used only when starting the mongodb container)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme
